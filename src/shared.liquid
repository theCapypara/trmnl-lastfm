{% template content %}
{% assign gridId = "grid-" | append_random %}
<div class="layout layout--col p--2">
    <div id="{{ gridId }}" class="grid w--full grid--cols-{{ num_cols }} gap--small">
        {% for album in data.albums %}
            <img
                    src="{{ album['image'] }}"
                    class="
                        image image--contain image-dither image--dither
                        w--full h--full
                        aspect--1/1
                    "
            >
        {% endfor %}
    </div>
</div>
<script>
    // Remove all overflowing elements
    const grid = document.querySelector('#{{ gridId }}');
    const bottom = grid.parentElement.getBoundingClientRect().bottom - 15;
    const gridElems = grid.querySelectorAll('#{{ gridId }} *');
    outer: while (true) {
        for (const el of gridElems) {
            if (el.getBoundingClientRect().bottom >= bottom) {
                el.style.display = 'none';
                // we restart iteration since elements may have reflowed now. a bit hacky,
                // happy to hear better solutions to this.
                continue outer;
            }
        }
        break;
    }
</script>
{% endtemplate %}

{% template title_bar %}
{% if trmnl.user.locale == "de" %}
    {% case trmnl.plugin_settings.custom_fields_values.range %}
        {% when "recent" %}
            {% assign human_readable_range = "zuletzt gespielt" %}
        {% when "7day" %}
            {% assign human_readable_range = "letzte Woche" %}
        {% when "1month" %}
            {% assign human_readable_range = "letzter Monat" %}
        {% when "3month" %}
            {% assign human_readable_range = "3 Monate" %}
        {% when "6month" %}
            {% assign human_readable_range = "6 Monate" %}
        {% when "12month" %}
            {% assign human_readable_range = "12 Monate" %}
        {% when "overall" %}
            {% assign human_readable_range = "Top-Alben" %}
    {% endcase %}
{% else %}
    {% case trmnl.plugin_settings.custom_fields_values.range %}
        {% when "recent" %}
            {% assign human_readable_range = "recently played" %}
        {% when "7day" %}
            {% assign human_readable_range = "last week" %}
        {% when "1month" %}
            {% assign human_readable_range = "last month" %}
        {% when "3month" %}
            {% assign human_readable_range = "3 months" %}
        {% when "6month" %}
            {% assign human_readable_range = "6 months" %}
        {% when "12month" %}
            {% assign human_readable_range = "12 months" %}
        {% when "overall" %}
            {% assign human_readable_range = "top albums" %}
    {% endcase %}
{% endif %}
<div class="title_bar">
    <svg class="image" fill="#000000" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
        <path d="M8.574 14.576c-.477.348-1.455 1.024-3.381 1.024C2.532 15.6 0 13.707 0 10.195 0 6.547 2.637 4.4 5.354 4.4c3.047 0 4.183 1.108 5.144 4.109l.756 2.309c.551 1.688 1.713 2.91 4.026 2.91 1.558 0 2.382-.346 2.382-1.199 0-.67-.389-1.156-1.557-1.434l-1.559-.369c-1.9-.461-2.656-1.455-2.656-3.025 0-2.516 2.016-3.301 4.077-3.301 2.337 0 3.757.854 3.94 2.932l-2.291.277c-.092-.992-.688-1.408-1.787-1.408-1.008 0-1.627.461-1.627 1.246 0 .693.299 1.109 1.307 1.34l1.466.324c1.97.461 3.025 1.432 3.025 3.303 0 2.309-1.924 3.186-4.766 3.186-3.963 0-5.338-1.801-6.07-4.041L8.43 9.25c-.549-1.687-.99-2.902-3.006-2.902-1.398 0-3.219.916-3.219 3.756 0 2.217 1.523 3.604 3.104 3.604 1.34 0 2.146-.754 2.564-1.131l.701 1.999z"/>
    </svg>
    <span class="title">{{ trmnl.plugin_settings.custom_fields_values.username }} ({{ human_readable_range }})</span>
    <span class="instance">{{ trmnl.plugin_settings.instance_name }}</span>
</div>
{% endtemplate %}

{% template error_info %}
<div class="layout w--full h--full">
    <div class="flex flex--row gap--xlarge">
        <div><img src="https://capypara.de/caution.svg" class="w--36"></div>
        <div class="stretch-x">
            <p><span class="title">Failed loading Last.fm Albums</span></p>
            </p>
            <span class="description description--large">
                    <ul>
                        {% for error in errors %}
                            <li>{{ error }}</li>
                        {% endfor %}
                    </ul>
                    <br>
                </span>
            </p>
        </div>
    </div>
</div>
{% endtemplate %}